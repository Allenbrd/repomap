datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
}

model Charge {
  id       Int      @id @default(autoincrement())
  amount   Float
  date     DateTime
  refunded Boolean  @default(false)
}

model Invoice {
  id   Int      @id @default(autoincrement())
  date DateTime
}
